      "types": "./dist/entities/index.d.ts",
      "default": "./dist/entities/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "entities": ["dist/entities/index.d.ts"]
    }
  },
  "peerDependencies": {
    "typeorm": "^0.3.28"
  }
}